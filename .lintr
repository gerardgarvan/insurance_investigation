linters: linters_with_defaults(
    pipe_consistency_linter = pipe_consistency_linter("%>%"),
    object_usage_linter = NULL,
    line_length_linter = line_length_linter(150L),
    return_linter = NULL,
    object_length_linter = NULL,
    object_name_linter = NULL
  )
exclusions: list(
    "R/archive" = list()
  )
